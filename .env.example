# review-deck environment. Copy to .env and fill in what you need (.env is gitignored).

# --- Claude reviewer (required for reviews) ---
# Generate with `claude setup-token`, OR omit this and start the server from a
# shell where you're already logged into Claude Code (the SDK inherits that login).
CLAUDE_CODE_OAUTH_TOKEN=

# --- Codex reviewer (required unless the Codex engine is disabled in ⚙ Settings) ---
# Preferred: run `codex login` once (ChatGPT login, stored in ~/.codex/auth.json)
# and leave this unset. Otherwise, provide an OpenAI API key here.
# OPENAI_API_KEY=

# --- Linear ticket intent (optional) ---
# Personal API key from Linear → Settings → Security & access → Personal API keys.
# When set, triage pulls linked ticket context into the summary.
# LINEAR_API_KEY=

# --- Server ---
# PORT=3001
