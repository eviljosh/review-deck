{
  "name": "review-deck",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Local web app to review many GitHub PRs in parallel.",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "concurrently -k -n server,ui -c blue,magenta \"npm:dev:server\" \"npm:dev:ui\"",
    "dev:server": "tsx watch src/server/index.ts",
    "dev:ui": "vite",
    "build": "vite build",
    "start": "cross-env NODE_ENV=production tsx src/server/index.ts",
    "typecheck": "tsc --noEmit",
    "test": "node --import tsx --test test/*.test.ts"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.3.211",
    "@fastify/static": "^8.0.3",
    "@fastify/websocket": "^11.0.1",
    "@openai/codex-sdk": "^0.144.5",
    "better-sqlite3": "^11.8.1",
    "dotenv": "^16.4.7",
    "fastify": "^5.2.1",
    "p-limit": "^7.3.0",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.10.7",
    "@types/react": "^19.0.7",
    "@types/react-dom": "^19.0.3",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.2",
    "cross-env": "^7.0.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vite": "^6.0.7"
  }
}
